{
    "title": "ProductOS AI \u2014 API & Workers",
    "uid": "productos-ai-overview",
    "schemaVersion": 39,    
    "version": 1,
    "refresh": "30s",
    "tags": ["productos-ai"],
    "time": { "from": "now-6h", "to": "now" },
    "timepicker": {},
    "templating": { "list": [] },
    "annotations": { "list": []},
    "editable": true,
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "API request rate (RPS)",
            "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "expr": "sum(rate(http_requests_total[5m]))",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
                "colorMode": "value",
                "graphMode": "area"
            }
        },
        {
            "id": 2,
            "type": "stat",
            "title": "5xx error rate",
            "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0},
            "datasource": { "type": "prometheus", "uid": "prometheus"},
            "targets": [
                {
                    "expr": "sum(rate(http_requests_total{status=~\"5..\"][5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {"color": "green", "value": null},
                            {"color": "orange", "value": 0.01},
                            {"color": "red", "value": 0.05}
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": {"calcs": ["last"], "fields": "", "values": false },
                "colorMode": "value",
                "graphMode": "area"
            }
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "API latency \u2014 p50/p95/p99",
            "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus"},
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
                    "refId": "p50",
                    "legendFormat": "p50"
                },
                {
                    "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
                    "refId": "p95",
                    "legendFormat": "995"
                },
                {
                    "expr": "histogram quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
                    "refId": "p99",
                    "legendFormat": "p99"
                }
            ],
            "fieldConfig": { "defaults": {"unit": "s" } }
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "Requests by status code",
            "gridPos": { "h": 9, "w": 12, "x": 0, "у": 9 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "expr": "sum by (status) (rate(http_requests_total[5m]))",
                    "refId": "A",
                    "legendFormat": "{{status}}"
                }
            ]
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "Top 10 slowest endpoints (p95)",
            "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
            "datasource": { "type": "prometheus", "uid": "prometheus"},
            "targets": [
                {
                    "expr": "topk(10, histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m]))))",
                    "refId": "A",
                    "legendFormat": "{{handler}}"
                }
            ],
            "fieldConfig": {"defaults": {"unit": "s"} }
        },
        {
            "id": 6,
            "type": "timeseries",
            "title": "Python process memory (RSS)",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes{job=\"productos_backend\"}",
                    "refId": "A",
                    "legendFormat": "backend RSS"
                }
            ],
            "fieldConfig": { "defaults": { "unit": "bytes"}}
        },
        {
            "id": 7,
            "type": "timeseries",
            "title": "Python GC collections",
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "expr": "sum by (generation) (rate(python_gc_collections_total[5m]))",
                    "refId": "A",
                    "legendFormat": "gen {{generation}}"
                }
            ]
        }
    ]
}